# Authenticity Validator for Academia - Backend Configuration

# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/authenticity-validator?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# OCR Configuration
OCR_ENGINE=tesseract
OCR_LANGUAGE=eng

# Email Configuration (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# AI/ML Configuration
ENABLE_AI_ANALYSIS=true
CONFIDENCE_THRESHOLD=0.7

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# API Documentation
API_DOCS_URL=/api-docs

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database Backup
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000
